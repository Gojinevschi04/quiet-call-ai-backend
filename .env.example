# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_db
DB_USER=app
DB_PASS=pass

# Storage Configuration
STORAGE_PATH=storage

# JWT Configuration (generate a secure random key: python -c "import secrets; print(secrets.token_urlsafe(48))")
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Twilio Configuration (https://www.twilio.com/console)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# OpenAI Configuration (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
OPENAI_STT_MODEL=whisper-1

# App Configuration
# IMPORTANT: For real calls, BASE_URL must be a public URL reachable by Twilio.
# Start ngrok first: ngrok http 8000
# Then set BASE_URL to the ngrok URL (e.g., https://xxxx.ngrok-free.app)
BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=300

# Test Phone Override (optional — when set, all calls go to this number instead of task's target_phone)
TEST_PHONE_OVERRIDE=

# Realtime API (OpenAI gpt-realtime + Twilio Media Streams)
# When USE_REALTIME_API=true, calls use bidirectional audio streaming (lower latency, barge-in, semantic VAD).
# When false, calls use the legacy <Gather>/<Say> webhook-driven flow.
USE_REALTIME_API=false
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=alloy
REALTIME_VAD_MODE=semantic_vad
REALTIME_VAD_EAGERNESS=medium

# Email Configuration (Gmail: Settings > Security > 2FA > App Passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@quietcall.ai
EMAIL_FROM_NAME=Quiet Call AI
EMAIL_ENABLED=false
FEEDBACK_EMAILS=your_email@gmail.com

# Logging
LOG_LEVEL=INFO
